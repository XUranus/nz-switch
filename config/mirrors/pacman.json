{
  "tool": "pacman",
  "display_name": "pacman",
  "description": "Arch Linux 包管理器 (含 archlinuxcn)",
  "config_type": "file",
  "config_path": "/etc/pacman.d/mirrorlist",
  "os": ["linux"],
  "arch": [],
  "mirrors": [
    {
      "name": "tuna",
      "display_name": "清华 TUNA",
      "url": "https://mirrors.tuna.tsinghua.edu.cn/archlinux/$repo/os/$arch",
      "os": [],
      "arch": [],
      "enabled": true,
      "env_vars": {
        "archlinuxcn": "https://mirrors.tuna.tsinghua.edu.cn/archlinuxcn/$arch"
      }
    },
    {
      "name": "aliyun",
      "display_name": "阿里云",
      "url": "https://mirrors.aliyun.com/archlinux/$repo/os/$arch",
      "os": [],
      "arch": [],
      "enabled": true,
      "env_vars": {
        "archlinuxcn": "https://mirrors.aliyun.com/archlinuxcn/$arch"
      }
    },
    {
      "name": "ustc",
      "display_name": "中科大",
      "url": "https://mirrors.ustc.edu.cn/archlinux/$repo/os/$arch",
      "os": [],
      "arch": [],
      "enabled": true,
      "env_vars": {
        "archlinuxcn": "https://mirrors.ustc.edu.cn/archlinuxcn/$arch"
      }
    },
    {
      "name": "163",
      "display_name": "网易",
      "url": "https://mirrors.163.com/archlinux/$repo/os/$arch",
      "os": [],
      "arch": [],
      "enabled": true,
      "env_vars": {
        "archlinuxcn": "https://mirrors.163.com/archlinuxcn/$arch"
      }
    },
    {
      "name": "huawei",
      "display_name": "华为云",
      "url": "https://repo.huaweicloud.com/archlinux/$repo/os/$arch",
      "os": [],
      "arch": [],
      "enabled": true,
      "env_vars": {
        "archlinuxcn": "https://repo.huaweicloud.com/archlinuxcn/$arch"
      }
    },
    {
      "name": "official",
      "display_name": "官方",
      "url": "https://geo.mirror.pkgbuild.com/$repo/os/$arch",
      "os": [],
      "arch": [],
      "enabled": true,
      "env_vars": {
        "archlinuxcn": "https://archlinuxcn.org/archlinuxcn/$arch"
      }
    }
  ]
}
